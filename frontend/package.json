{
  "name": "waf-agent-frontend",
  "version": "0.11.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node -e \"const fs=require('fs');const v=fs.readFileSync('../CHANGELOG.md','utf-8').match(/^## (\\d+\\.\\d+\\.\\d+)/m)?.[1]||'0.0.0';const p=JSON.parse(fs.readFileSync('./package.json','utf-8'));if(p.version!==v){p.version=v;fs.writeFileSync('./package.json',JSON.stringify(p,null,2)+'\\n')}\"",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "amazon-cognito-identity-js": "^6.3.0",
    "marked": "^18.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^6.0.0"
  },
  "overrides": {
    "js-cookie": "^3.0.7"
  }
}
