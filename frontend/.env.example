# Frontend Environment Variables
# Fill from CloudFormation stack outputs

VITE_USER_POOL_ID=<your-user-pool-id>
VITE_CLIENT_ID=<your-client-id>
VITE_REGION=<your-region>
VITE_AGENT_ENDPOINT=https://bedrock-agentcore.<your-region>.amazonaws.com
VITE_AGENT_RUNTIME_ARN=<your-agent-runtime-arn>
VITE_SESSIONS_API_URL=<your-sessions-api-url>

# Optional: branding override (for demos/custom deployments)
# VITE_BRAND_NAME=Amazon WAF Agent
# VITE_BRAND_NAME=My Company WAF Agent
